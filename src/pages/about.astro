---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import ArrowLink from '../components/ArrowLink.astro';
import ContactCTA from '../components/ContactCTA.astro';

const accreditations = [
  { name: 'ACCA', label: 'ACCA Employer Accreditation' },
  { name: 'ICAP', label: 'ICAP Registered Employer' },
  { name: 'ISO/UKSAS', label: 'ISO / UKSAS Certified' },
  { name: 'MUFAP', label: 'MUFAP Member' },
  { name: 'SECP', label: 'SECP Licensed' },
  { name: 'TREC', label: 'PSX TREC Holder' },
  { name: 'PSX', label: 'Pakistan Stock Exchange' },
];

const leadership = [
  { name: '[Name Placeholder]', title: 'Chief Executive Officer', image: 'https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&w=600&q=80' },
  { name: '[Name Placeholder]', title: 'Chief Investment Officer', image: 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=600&q=80' },
  { name: '[Name Placeholder]', title: 'Head of Private Wealth', image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=600&q=80' },
  { name: '[Name Placeholder]', title: 'Head of Asset Management', image: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=600&q=80' },
];
---

<BaseLayout
  title="About | Black Stone Islamic Global"
  description="Learn about Black Stone Islamic Global — our mission, accreditations, and leadership team."
>
  <!-- Our Firm statement -->
  <section class="py-section bg-paper border-b border-line">
    <div class="container-big">
      <p class="label mb-6">Our Firm</p>
      <h1 class="font-serif font-normal text-ink mb-16" style="font-size: clamp(36px, 6vw, 80px); line-height: 1.05; max-width: 900px;">
        We aspire to be the world's most trusted Shariah-compliant financial institution.
      </h1>

      <!-- Three photo row -->
      <div class="grid grid-cols-3 gap-4 mb-16">
        <div class="aspect-[4/3] bg-mist overflow-hidden">
          <img src="https://images.unsplash.com/photo-1573164574511-73c773193279?auto=format&fit=crop&w=800&q=80" alt="BIG team at work" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="aspect-[4/3] bg-mist overflow-hidden">
          <img src="https://images.unsplash.com/photo-1622675363311-3e1904dc1885?auto=format&fit=crop&w=800&q=80" alt="Investment advisory meeting" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="aspect-[4/3] bg-mist overflow-hidden">
          <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80" alt="BIG investment research in action" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>

      <!-- Narrative -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <h2 class="font-serif font-normal text-ink mb-4" style="font-size: clamp(24px, 2.5vw, 32px); line-height: 1.2;">
            Who We Are
          </h2>
        </div>
        <div class="lg:col-span-8 space-y-5 font-sans text-base text-stone leading-relaxed">
          <p>
            Black Stone Islamic Global (BIG) is a Shariah-compliant boutique brokerage, asset management, and private wealth management firm serving institutional and individual clients across Pakistan and globally. We are licensed by the Securities and Exchange Commission of Pakistan (SECP) and hold a Trading Right Entitlement Certificate (TREC) from the Pakistan Stock Exchange (PSX).
          </p>
          <p>
            Our practice combines deep capital-markets expertise with rigorous Islamic finance principles to deliver disciplined, faith-aligned investment solutions. We provide access to Pakistani equities (PSX), international equities (FTSE, NYSE), Shariah-compliant fixed income and Green Sukuks, mutual funds, ETFs, private equity, real estate, and specialized advisory services including M&A, IPOs, and family office management.
          </p>
          <p>
            At BIG, we believe that adherence to Shariah principles and the pursuit of superior investment performance are not competing objectives — they are mutually reinforcing. Our approach is built on transparency, trust, and a long-term commitment to our clients' financial well-being and legacy.
          </p>
          <p>
            We are accredited by ACCA and ICAP as a registered employer, and hold ISO and UKSAS certifications. We are also registered with MUFAP, reflecting our commitment to professional standards in fund distribution and advisory.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="py-section bg-mist">
    <div class="container-big">
      <p class="label mb-6">Our Approach</p>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <div>
          <div class="w-8 h-1 bg-acid mb-5"></div>
          <h3 class="font-sans font-bold text-sm text-ink uppercase tracking-wide mb-4">Shariah First</h3>
          <p class="font-sans text-sm text-stone leading-relaxed">
            Every investment, strategy, and product is independently screened and certified Shariah-compliant before it reaches our clients. Faith-aligned investing is not a constraint — it is our foundation.
          </p>
        </div>
        <div>
          <div class="w-8 h-1 bg-acid mb-5"></div>
          <h3 class="font-sans font-bold text-sm text-ink uppercase tracking-wide mb-4">Research-Driven</h3>
          <p class="font-sans text-sm text-stone leading-relaxed">
            Our investment decisions are grounded in proprietary research, quantitative analysis, and deep fundamental insight across Pakistani and global capital markets.
          </p>
        </div>
        <div>
          <div class="w-8 h-1 bg-acid mb-5"></div>
          <h3 class="font-sans font-bold text-sm text-ink uppercase tracking-wide mb-4">Client-Centric</h3>
          <p class="font-sans text-sm text-stone leading-relaxed">
            We build long-term relationships grounded in trust and transparency. Our high-touch, bespoke advisory model means your goals, risk profile, and legacy objectives always come first.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Accreditations -->
  <section class="py-section bg-paper border-t border-line">
    <div class="container-big">
      <p class="label mb-8">Accreditations & Memberships</p>
      <div class="flex flex-wrap items-center gap-6">
        {accreditations.map(acc => (
          <div class="border border-line px-6 py-4 flex items-center justify-center min-w-[140px]">
            <span class="font-sans font-bold text-sm text-ink tracking-wide">{acc.name}</span>
          </div>
        ))}
      </div>
      <p class="font-sans text-xs text-stone mt-6">
        ACCA · ICAP · ISO/UKSAS · MUFAP · SECP · TREC · PSX
      </p>
    </div>
  </section>

  <!-- Leadership -->
  <section class="py-section bg-mist border-t border-line">
    <div class="container-big">
      <p class="label mb-6">Leadership & Board</p>
      <h2 class="font-serif font-normal text-ink mb-12" style="font-size: clamp(28px, 3vw, 40px); line-height: 1.1;">
        Experienced. Principled. Client-Focused.
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {leadership.map(person => (
          <div>
            <div class="aspect-[3/4] bg-stone/10 mb-4 overflow-hidden">
              <img
                src={person.image}
                alt={person.name}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <p class="font-sans font-semibold text-sm text-ink mb-1">{person.name}</p>
            <p class="font-sans text-xs text-stone">{person.title}</p>
          </div>
        ))}
      </div>
      <p class="font-sans text-xs text-stone mt-8 italic">
        Leadership profiles are placeholder pending client confirmation.
      </p>
    </div>
  </section>

  <ContactCTA
    headline="Speak with Our Team"
    subtext="We would welcome the opportunity to discuss how BIG can serve your investment and advisory needs."
    image="https://images.unsplash.com/photo-1551836022-d5d88e9218df?auto=format&fit=crop&w=1200&q=80"
    imageAlt="BIG wealth advisor in client consultation"
  />
</BaseLayout>
