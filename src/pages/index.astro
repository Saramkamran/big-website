---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import StatBand from '../components/StatBand.astro';
import NewsletterBand from '../components/NewsletterBand.astro';
import Button from '../components/Button.astro';
import ContactCTA from '../components/ContactCTA.astro';

const insights = [
  {
    slug: 'pakistan-equity-outlook-2026',
    category: 'MARKETS',
    title: 'Pakistan Equity Outlook 2026: Navigating Reform and Recovery',
    type: 'Article',
    date: 'Jun 12, 2026',
    image: 'https://images.unsplash.com/photo-1637679149566-6af21b6e933a?auto=format&fit=crop&w=900&q=80',
    featured: true,
  },
  {
    slug: 'green-sukuk-growth-esgs',
    category: 'SUSTAINABLE FINANCE',
    title: 'Green Sukuk: Pakistan\'s Gateway to ESG Capital Markets',
    type: 'Article',
    date: 'Jun 5, 2026',
    image: 'https://images.unsplash.com/photo-1595437193398-f24279553f4f?auto=format&fit=crop&w=900&q=80',
    featured: false,
  },
  {
    slug: 'shariah-screening-methodology',
    category: 'SHARIAH COMPLIANCE',
    title: 'How Our Shariah Screening Methodology Works',
    type: 'Video',
    date: 'May 28, 2026',
    image: 'https://images.unsplash.com/photo-1612178991541-b48cc8e92a4d?auto=format&fit=crop&w=900&q=80',
    featured: false,
  },
  {
    slug: 'wealth-planning-overseas-pakistanis',
    category: 'PRIVATE WEALTH',
    title: 'Wealth Planning for Overseas Pakistanis: Key Considerations',
    type: 'Podcast',
    date: 'May 20, 2026',
    image: 'https://images.unsplash.com/photo-1699621106755-4fe40ce95d64?auto=format&fit=crop&w=900&q=80',
    featured: false,
  },
];

const firmInAction = [
  {
    category: 'AWARDS & RECOGNITION',
    title: 'BIG Recognised as Top Shariah-Compliant Brokerage in Pakistan',
    image: 'https://images.unsplash.com/photo-1573164574511-73c773193279?auto=format&fit=crop&w=800&q=80',
    excerpt: 'Black Stone Islamic Global has been honoured for its commitment to Shariah-compliant investing and client excellence.',
  },
  {
    category: 'DEAL SPOTLIGHT',
    title: 'Advising on Pakistan\'s First Sovereign Green Sukuk Issuance',
    image: 'https://images.unsplash.com/photo-1622675363311-3e1904dc1885?auto=format&fit=crop&w=800&q=80',
    excerpt: 'BIG advised on a landmark Rs 25B sovereign green sukuk transaction, channelling capital into renewable energy.',
  },
  {
    category: 'AWARDS & RECOGNITION',
    title: 'ACCA & ICAP Employer Accreditation Renewed for 2026',
    image: 'https://images.unsplash.com/photo-1551836022-d5d88e9218df?auto=format&fit=crop&w=800&q=80',
    excerpt: 'BIG maintains its prestigious ACCA and ICAP employer accreditations, reflecting our investment in professional talent.',
  },
];
---

<BaseLayout>
  <Hero />

  <StatBand />

  <!-- ── What We Do header ─────────────────────────────────────────────── -->
  <section id="what-we-do" class="py-16 lg:py-20 bg-paper border-t border-line">
    <div class="container-big">
      <p class="label mb-4">What We Do</p>
      <h2
        class="font-serif font-normal text-ink"
        style="font-size: clamp(32px, 4vw, 52px); line-height: 1.1; max-width: 640px;"
      >
        Delivering for Our Clients
      </h2>
    </div>
  </section>

  <!-- ── Pillar 1: PSX & Global Markets — image left ───────────────────── -->
  <section id="psx-global-markets" class="border-t border-line">
    <div class="grid grid-cols-1 lg:grid-cols-2" style="min-height: 580px;">
      <!-- Full-bleed image -->
      <div class="overflow-hidden min-h-[280px] lg:min-h-0">
        <img
          src="https://images.unsplash.com/photo-1761233138997-44d9b002a08f?auto=format&fit=crop&w=1400&q=80"
          alt="NYSE stock exchange — PSX and global markets"
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
      <!-- Text -->
      <div class="bg-paper flex items-center px-8 py-16 lg:px-14 xl:px-20">
        <div class="max-w-xl w-full">
          <p class="label mb-4">PSX &amp; Global Markets</p>
          <h2
            class="font-serif font-normal text-ink mb-5"
            style="font-size: clamp(24px, 2.8vw, 38px); line-height: 1.15;"
          >
            Halal Capital.<br/>Disciplined Research.<br/>Global Markets.
          </h2>
          <p class="font-sans text-sm text-stone leading-relaxed mb-7">
            Our Shariah-compliant boutique equities business combines disciplined investment research, rigorous Islamic screening, and deep market expertise to deliver tailored halal investment solutions for institutional and individual investors.
          </p>
          <ul class="mb-8 space-y-2.5">
            {['Shariah Equities', 'Green Sukuks', 'Transaction Services', 'Blackstone Intel', 'Blackstone Investments'].map(s => (
              <li class="flex items-center gap-3 font-sans text-sm text-ink">
                <span class="w-1.5 h-1.5 bg-acid flex-shrink-0"></span>{s}
              </li>
            ))}
          </ul>
          <a
            href="/what-we-do/psx-global-markets"
            class="group inline-flex items-center gap-3 bg-acid text-ink font-sans font-semibold text-sm px-8 py-4 transition-all duration-300 hover:bg-ink hover:text-white"
          >
            Explore PSX &amp; Global Markets
            <span class="inline-block transition-transform duration-300 group-hover:translate-x-1.5" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Pillar 2: Asset Management — image right ──────────────────────── -->
  <section id="asset-management" class="border-t border-line">
    <div class="grid grid-cols-1 lg:grid-cols-2" style="min-height: 580px;">
      <!-- Text (shows below image on mobile, left on desktop) -->
      <div class="bg-mist flex items-center px-8 py-16 lg:px-14 xl:px-20 order-2 lg:order-1">
        <div class="max-w-xl w-full">
          <p class="label mb-4">Asset Management</p>
          <h2
            class="font-serif font-normal text-ink mb-5"
            style="font-size: clamp(24px, 2.8vw, 38px); line-height: 1.15;"
          >
            Shariah-Screened.<br/>Professionally Managed.<br/>Built for Growth.
          </h2>
          <p class="font-sans text-sm text-stone leading-relaxed mb-7">
            Our comprehensive suite of asset-management solutions across fixed income, equity, and multi-asset strategies is designed to navigate market challenges and deliver returns aligned with your expectations — within the bounds of Islamic finance.
          </p>
          <ul class="mb-8 space-y-2.5">
            {['Shariah Fixed Income', 'Shariah Equity', 'Shariah ETFs', 'Shariah Multi-Asset', 'Shariah Pensions'].map(s => (
              <li class="flex items-center gap-3 font-sans text-sm text-ink">
                <span class="w-1.5 h-1.5 bg-acid flex-shrink-0"></span>{s}
              </li>
            ))}
          </ul>
          <a
            href="/what-we-do/asset-management"
            class="group inline-flex items-center gap-3 bg-acid text-ink font-sans font-semibold text-sm px-8 py-4 transition-all duration-300 hover:bg-ink hover:text-white"
          >
            Explore Asset Management
            <span class="inline-block transition-transform duration-300 group-hover:translate-x-1.5" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
      <!-- Full-bleed image -->
      <div class="overflow-hidden min-h-[280px] lg:min-h-0 order-1 lg:order-2">
        <img
          src="https://images.unsplash.com/photo-1773503877076-cc9caa3322ff?auto=format&fit=crop&w=1400&q=80"
          alt="City at dusk — long-term asset management"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ── Pillar 3: Private Wealth — image left ─────────────────────────── -->
  <section id="private-wealth" class="border-t border-line">
    <div class="grid grid-cols-1 lg:grid-cols-2" style="min-height: 580px;">
      <!-- Full-bleed image -->
      <div class="overflow-hidden min-h-[280px] lg:min-h-0">
        <img
          src="https://images.unsplash.com/photo-1770070553064-3980a912f96b?auto=format&fit=crop&w=1400&q=80"
          alt="Professional private wealth advisor"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
      <!-- Text -->
      <div class="bg-paper flex items-center px-8 py-16 lg:px-14 xl:px-20">
        <div class="max-w-xl w-full">
          <p class="label mb-4">Private Wealth Management</p>
          <h2
            class="font-serif font-normal text-ink mb-5"
            style="font-size: clamp(24px, 2.8vw, 38px); line-height: 1.15;"
          >
            Your Wealth.<br/>Your Legacy.<br/>Your Terms.
          </h2>
          <p class="font-sans text-sm text-stone leading-relaxed mb-7">
            We take a highly personalised à la carte approach to understanding your wealth aspirations, financial commitments, and life goals — designing bespoke solutions that preserve and grow wealth across generations.
          </p>
          <ul class="mb-8 space-y-2.5">
            {['Wealth Planning', 'Dedicated Investments', 'Private Equity', 'Real Estate', 'Pakistan Energy', 'Philanthropy & Zakat', 'Professional Services'].map(s => (
              <li class="flex items-center gap-3 font-sans text-sm text-ink">
                <span class="w-1.5 h-1.5 bg-acid flex-shrink-0"></span>{s}
              </li>
            ))}
          </ul>
          <a
            href="/what-we-do/private-wealth"
            class="group inline-flex items-center gap-3 bg-acid text-ink font-sans font-semibold text-sm px-8 py-4 transition-all duration-300 hover:bg-ink hover:text-white"
          >
            Explore Private Wealth
            <span class="inline-block transition-transform duration-300 group-hover:translate-x-1.5" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Pillar 4: Specialized Services — image right ──────────────────── -->
  <section id="specialized-services" class="border-t border-line">
    <div class="grid grid-cols-1 lg:grid-cols-2" style="min-height: 580px;">
      <!-- Text -->
      <div class="bg-mist flex items-center px-8 py-16 lg:px-14 xl:px-20 order-2 lg:order-1">
        <div class="max-w-xl w-full">
          <p class="label mb-4">Specialized Services</p>
          <h2
            class="font-serif font-normal text-ink mb-5"
            style="font-size: clamp(24px, 2.8vw, 38px); line-height: 1.15;"
          >
            Distinctive Solutions<br/>for Complex Needs.
          </h2>
          <p class="font-sans text-sm text-stone leading-relaxed mb-7">
            Our specialized advisory capabilities address the full breadth of sophisticated client requirements — from multi-generational family wealth oversight to cross-border M&amp;A mandates and equity capital markets transactions.
          </p>
          <ul class="mb-8 space-y-2.5">
            {['BIG Family Office', 'Alternative Investments', 'M&A and Carve-Out', 'IPOs (Pakistan & US)'].map(s => (
              <li class="flex items-center gap-3 font-sans text-sm text-ink">
                <span class="w-1.5 h-1.5 bg-acid flex-shrink-0"></span>{s}
              </li>
            ))}
          </ul>
          <a
            href="/what-we-do/specialized-services"
            class="group inline-flex items-center gap-3 bg-acid text-ink font-sans font-semibold text-sm px-8 py-4 transition-all duration-300 hover:bg-ink hover:text-white"
          >
            Explore Specialized Services
            <span class="inline-block transition-transform duration-300 group-hover:translate-x-1.5" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
      <!-- Full-bleed image -->
      <div class="overflow-hidden min-h-[280px] lg:min-h-0 order-1 lg:order-2">
        <img
          src="https://images.unsplash.com/photo-1780907058575-050e066f6671?auto=format&fit=crop&w=1400&q=80"
          alt="City skyline over water — specialized corporate advisory"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ── Insights Preview ───────────────────────────────────────────────── -->
  <section class="py-section bg-paper border-t border-line">
    <div class="container-big">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12">
        <h2
          class="font-serif font-normal text-ink"
          style="font-size: clamp(28px, 4vw, 52px); line-height: 1.1;"
        >
          Insights on Islamic Finance<br/>and Global Markets
        </h2>
        <Button variant="outline" href="/insights">Explore All Insights</Button>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        {insights.filter(i => i.featured).slice(0, 1).map(item => (
          <div class="lg:col-span-7">
            <a href={`/insights/${item.slug}`} class="block group">
              <div class="overflow-hidden mb-6 bg-mist aspect-video">
                <img
                  src={item.image}
                  alt={item.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <p class="label mb-3">{item.category}</p>
              <h3
                class="font-serif font-normal text-ink mb-3 group-hover:underline"
                style="font-size: clamp(20px, 2.5vw, 28px); line-height: 1.2;"
              >
                {item.title}
              </h3>
              <p class="font-sans text-meta text-stone">{item.type} | {item.date}</p>
            </a>
          </div>
        ))}

        <div class="lg:col-span-5">
          {insights.filter(i => !i.featured).map(item => (
            <a
              href={`/insights/${item.slug}`}
              class="flex gap-4 py-6 border-t border-line group hover:bg-mist -mx-4 px-4 transition-colors"
            >
              <div class="w-24 h-20 flex-shrink-0 overflow-hidden bg-mist">
                <img
                  src={item.image}
                  alt={item.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="flex-1 min-w-0">
                <p class="label mb-2">{item.category}</p>
                <h4
                  class="font-serif font-normal text-ink leading-snug mb-2 group-hover:underline"
                  style="font-size: 16px;"
                >
                  {item.title}
                </h4>
                <p class="font-sans text-xs text-stone">{item.type} | {item.date}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── The Firm in Action ─────────────────────────────────────────────── -->
  <section class="py-section bg-mist border-t border-line">
    <div class="container-big">
      <p class="label mb-4">Stay Informed</p>
      <h2
        class="font-serif font-normal text-ink mb-12"
        style="font-size: clamp(28px, 4vw, 48px); line-height: 1.1;"
      >
        The Firm in Action
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {firmInAction.map(item => (
          <div>
            <div class="overflow-hidden mb-5 bg-stone/10 aspect-[4/3]">
              <img
                src={item.image}
                alt={item.title}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <p class="label mb-3">{item.category}</p>
            <h3
              class="font-serif font-normal text-ink mb-3 leading-snug"
              style="font-size: clamp(18px, 1.8vw, 22px);"
            >
              {item.title}
            </h3>
            <p class="font-sans text-sm text-stone leading-relaxed">{item.excerpt}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ContactCTA />

  <NewsletterBand />
</BaseLayout>
