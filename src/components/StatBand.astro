---
import Button from './Button.astro';
import ArrowLink from './ArrowLink.astro';
---

<section class="bg-mist py-section">
  <div class="container-big">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-16 mb-12">
      <!-- Stat 1 -->
      <div>
        <p class="font-serif font-normal text-ink mb-2" style="font-size: clamp(48px, 6vw, 72px); line-height: 1;">
          25+
        </p>
        <p class="font-sans font-bold text-sm text-ink uppercase tracking-wide leading-snug">
          Years Combined PSX, FTSE &amp; NYSE Market Expertise
        </p>
      </div>
      <!-- Stat 2 -->
      <div>
        <p class="font-serif font-normal text-ink mb-2" style="font-size: clamp(48px, 6vw, 72px); line-height: 1;">
          100%
        </p>
        <p class="font-sans font-bold text-sm text-ink uppercase tracking-wide leading-snug">
          Shariah-Screened — Every Portfolio Independently Compliance-Checked
        </p>
      </div>
      <!-- Stat 3 -->
      <div>
        <p class="font-serif font-normal text-ink mb-2" style="font-size: clamp(48px, 6vw, 72px); line-height: 1;">
          3
        </p>
        <p class="font-sans font-bold text-sm text-ink uppercase tracking-wide leading-snug">
          Markets — PSX · FTSE · NYSE Access for Local &amp; Overseas Investors
        </p>
      </div>
    </div>

    <!-- Disclaimer -->
    <p class="font-sans text-xs text-stone mb-10 border-l-2 border-line pl-3 max-w-xl">
      Figures are illustrative placeholders pending client confirmation.
    </p>

    <!-- CTA links -->
    <div class="flex items-center gap-8 flex-wrap">
      <Button variant="outline" href="/about">Our Firm</Button>
      <ArrowLink href="/contact">Contact</ArrowLink>
    </div>
  </div>
</section>
