---
interface Props {
  variant?: 'ink' | 'acid' | 'outline';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
}

const { variant = 'ink', href, type = 'button', class: className = '' } = Astro.props;

const base = 'inline-flex items-center justify-center px-6 py-3 font-sans text-sm font-semibold tracking-wide transition-all duration-200 cursor-pointer border';

const variants = {
  ink:     'bg-ink text-white border-ink hover:bg-stone',
  acid:    'bg-acid text-ink border-acid hover:bg-acid-600',
  outline: 'bg-transparent text-ink border-ink hover:bg-ink hover:text-white',
};

const classes = `${base} ${variants[variant]} ${className}`;
---

{href
  ? <a href={href} class={classes}><slot /></a>
  : <button type={type} class={classes}><slot /></button>
}
