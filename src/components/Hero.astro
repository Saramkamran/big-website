---
import Button from './Button.astro';
---

<section
  class="relative flex items-end bg-ink"
  style="min-height: calc(100vh - var(--header-h));"
>
  <!-- Background layer — overflow-hidden stays HERE, never on the section -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      style="background-image: url('https://images.unsplash.com/photo-1759210720487-c74d9764da79?auto=format&fit=crop&w=2400&q=80');"
    ></div>
    <!-- Light gradient overlay — image stays visible -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(110deg, rgba(11,11,11,0.62) 0%, rgba(11,11,11,0.25) 55%, rgba(11,11,11,0.04) 100%);"
    ></div>
    <!-- Decorative oversized BIG watermark -->
    <div
      class="absolute top-0 right-0 font-sans font-extrabold text-white/5 select-none pointer-events-none leading-none"
      style="font-size: clamp(120px, 20vw, 280px); letter-spacing: -0.04em; transform: translate(5%, -5%);"
    >
      BIG
    </div>
  </div>

  <!-- Content: always visible — no overflow-hidden above this div -->
  <div class="relative z-10 container-big w-full pt-12 pb-20 md:pb-28">
    <div class="max-w-2xl">
      <p class="label text-acid mb-6">Shariah-Compliant Investing</p>
      <h1 class="font-serif text-white font-normal leading-[1.05] mb-8" style="font-size: clamp(40px, 6vw, 78px);">
        Principled capital.<br/>Halal growth.<br/>Global reach.
      </h1>
      <p class="font-sans text-white/80 text-lg leading-relaxed mb-10 max-w-xl">
        Black Stone Islamic Global delivers disciplined, Shariah-compliant brokerage, asset management, and private wealth solutions across the Pakistan Stock Exchange and global markets.
      </p>
      <Button variant="acid" href="/#what-we-do">Explore What We Do</Button>
    </div>
  </div>
</section>
