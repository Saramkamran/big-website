---
---

<footer class="bg-ink text-white">
  <!-- Main footer columns -->
  <div class="container-big py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 mb-6">
          <span class="font-sans font-extrabold text-2xl tracking-[-0.04em] text-white leading-none">BIG</span>
        </a>
        <p class="font-sans text-sm text-white/60 leading-relaxed max-w-[180px]">
          Black Stone Islamic Global<br/>Shariah-compliant brokerage &amp; wealth management.
        </p>
      </div>

      <!-- What We Do -->
      <div>
        <p class="label text-white/50 mb-5">What We Do</p>
        <ul class="space-y-3">
          <li><a href="/#shariah-equities" class="footer-link">Shariah Equities</a></li>
          <li><a href="/#green-sukuks" class="footer-link">Green Sukuks</a></li>
          <li><a href="/#transaction-services" class="footer-link">Transaction Services</a></li>
          <li><a href="/#am-equity" class="footer-link">Asset Management</a></li>
          <li><a href="/#wealth-planning" class="footer-link">Private Wealth</a></li>
          <li><a href="/#family-office" class="footer-link">Specialized Services</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <p class="label text-white/50 mb-5">Resources</p>
        <ul class="space-y-3">
          <li><a href="/login" class="footer-link">Account Login</a></li>
          <li><a href="/insights" class="footer-link">Insights</a></li>
          <li><a href="#" class="footer-link">Pressroom</a></li>
          <li><a href="#" class="footer-link">Onboarding</a></li>
          <li><a href="/contact" class="footer-link">Contact</a></li>
        </ul>
      </div>

      <!-- Our Businesses -->
      <div>
        <p class="label text-white/50 mb-5">Our Businesses</p>
        <ul class="space-y-3">
          <li><a href="/#shariah-equities" class="footer-link">PSX &amp; Global Markets</a></li>
          <li><a href="/#am-fixed-income" class="footer-link">Asset Management</a></li>
          <li><a href="/#wealth-planning" class="footer-link">Private Wealth Mgmt</a></li>
          <li><a href="/#family-office" class="footer-link">Specialized Services</a></li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <p class="label text-white/50 mb-5">Connect</p>
        <div class="flex gap-4 mb-6">
          <!-- LinkedIn -->
          <a href="#" aria-label="LinkedIn" class="social-icon">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a href="#" aria-label="Instagram" class="social-icon">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <!-- YouTube -->
          <a href="#" aria-label="YouTube" class="social-icon">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
            </svg>
          </a>
          <!-- X / Twitter -->
          <a href="#" aria-label="X (Twitter)" class="social-icon">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
        <a href="/contact" class="font-sans text-sm text-white/70 hover:text-acid transition-colors">Get in touch →</a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="container-big py-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="font-sans text-sm text-white/50">
        © 2026 Black Stone Islamic Global. All rights reserved.
      </p>
      <nav class="flex items-center gap-6 flex-wrap justify-center" aria-label="Legal navigation">
        <a href="#" class="footer-legal-link">Privacy &amp; Cookies</a>
        <a href="#" class="footer-legal-link">Terms &amp; Conditions</a>
        <a href="#" class="footer-legal-link">Regulatory Disclosures</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    @apply font-sans text-sm text-white/70 hover:text-acid transition-colors;
  }
  .social-icon {
    @apply text-white/60 hover:text-acid transition-colors;
  }
  .footer-legal-link {
    @apply font-sans text-xs text-white/40 hover:text-white/70 transition-colors;
  }
</style>
